# Environment variables for DreamScape Backend

# Server
PORT=5000
NODE_ENV=development
FEATURE_ORACLE_ENABLED=false
ORACLE_OLLAMA_CHAT_MODEL=qwen2.5:14b
ORACLE_OLLAMA_ANALYSIS_MODEL=qwen3.6:27b

# MongoDB
MONGODB_URI=mongodb://localhost:27017/dreamscape

# JWT
JWT_SECRET=your_super_secret_key_k9_term8
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Original PDFs use Firebase Storage. Cloudinary remains responsible for figures/images.
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
ORIGINAL_PDF_STORAGE_PROVIDER=firebase
# Oracle model routing. Local Ollama remains the safe default.
ORACLE_MODEL_PROVIDER=ollama
ORACLE_CONTEXT_WINDOW=32768
# Dedicated secret used to AES-256-GCM encrypt per-user model credentials.
# Use at least 32 random characters. JWT_SECRET is used only as a development fallback.
ORACLE_CREDENTIAL_ENCRYPTION_KEY=
# Optional OpenAI-compatible provider. Enabling it may send authorized private
# Oracle context to that provider; keep disabled until the product privacy
# notice/consent flow is approved.
# ORACLE_MODEL_PROVIDER=openai_compatible
# ORACLE_EXTERNAL_API_BASE_URL=https://api.openai.com/v1
# ORACLE_EXTERNAL_API_KEY=
# ORACLE_EXTERNAL_MODEL=
# ORACLE_EXTERNAL_PRIVATE_CONTEXT_ACKNOWLEDGED=false
